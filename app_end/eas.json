{
  "cli": {
    "version": ">= 5.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "production": {
      "cache": {
        "key": "local-cache-v1",
        "paths": [
          "node_modules",
          ".expo",
          ".npm",
          "android/.gradle"
        ]
      },
      "android": {
        "buildType": "apk"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "cache": {
        "key": "local-cache-v1",
        "paths": [
          "node_modules",
          ".expo",
          ".npm",
          "android/.gradle"
        ]
      },
      "android": { "buildType": "apk" }
    }
  }
}
