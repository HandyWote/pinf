# 基础密钥
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# 数据库（推荐 PostgreSQL）
# Compose 内网示例: postgresql://user:password@pgvector:5432/postgres_db
DATABASE_URL=postgresql://pinf:pinf@pgvector:5432/postgres_db

# n8n Webhook（内网即可）
N8N_WEBHOOK_URL=http://n8n:5678/webhook/waend

# 微信公众号（内容同步）
WECHAT_APP_ID=your-official-account-app-id
WECHAT_APP_SECRET=your-official-account-app-secret
WECHAT_API_TIMEOUT=10
WECHAT_SYNC_ENABLED=false
WECHAT_SYNC_INTERVAL_MINUTES=60
WECHAT_SYNC_MAX_PAGES=5
WECHAT_SYNC_PAGE_SIZE=20
WECHAT_SYNC_RETRY=3



# 运行环境
FLASK_ENV=development
