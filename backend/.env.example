# 基础密钥
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# 数据库（推荐 PostgreSQL）
# 示例: postgresql://user:password@localhost:5432/waend
DATABASE_URL=postgresql://pinf:password@localhost:5432/pinf

# n8n Webhook（内网即可）
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/waend

# 微信公众号（内容同步）
WECHAT_APP_ID=your-official-account-app-id
WECHAT_APP_SECRET=your-official-account-app-secret
WECHAT_API_TIMEOUT=10
WECHAT_SYNC_ENABLED=false
WECHAT_SYNC_INTERVAL_MINUTES=60
WECHAT_SYNC_MAX_PAGES=5
WECHAT_SYNC_PAGE_SIZE=20
WECHAT_SYNC_RETRY=3



# 运行环境
FLASK_ENV=development
