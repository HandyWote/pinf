# 基础密钥
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# 数据库（推荐 PostgreSQL）
# Compose 内网示例: postgresql://user:password@pgvector:5432/postgres_db
DATABASE_URL=postgresql://pinf:pinf@pgvector:5432/postgres_db

# n8n AI对话配置
N8N_WEBHOOK_URL=https://flows.pinf.top/webhook/chat
N8N_BASIC_AUTH_USER=你的用户名
N8N_BASIC_AUTH_PASSWORD=你的密码
N8N_TIMEOUT_SECONDS=120


# 通知/订阅调度（用于本地测试）
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_SCAN_INTERVAL_MINUTES=60



# 运行环境
FLASK_ENV=development
