# 基础密钥
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# 数据库（推荐 PostgreSQL）
# 示例: postgresql://user:password@localhost:5432/waend
DATABASE_URL=postgresql://pinf:password@localhost:5432/pinf

# n8n Webhook（内网即可）
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/waend



# 运行环境
FLASK_ENV=development
